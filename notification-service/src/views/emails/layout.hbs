<html xmlns='http://www.w3.org/1999/xhtml'>
	<head>
		<meta charset='UTF-8' />
		<meta http-equiv='X-UA-Compatible' content='IE=edge' />
		<meta name='viewport' content='width=device-width, initial-scale=1' />
		<title>{{title}}</title>
		<style>
			body{margin: 0;padding: 0;} .staak-email-container,a{ font-family: 'Lato','Helvetica Neue',Helvetica,Arial,sans-serif; } .staak-email-container{
			background: rgb(243,243,242); margin: 0;padding: 0;border-top: 3px solid #5B4FE3;width: 100%;height: 100%;padding-bottom: 60px; } .sized-table{
			width: 620px; } .header{margin-top: 35px;} .main-content{ background: #ffffff;border: 1px solid #ededed; padding: 20px 25px;margin: 25px 0;}
			.footer{margin-top: 35px;} .social-icon{ width: 50px;padding-left: 13px; } .gray-text{color: #696969 !important;opacity: .8;} .small-text{
			font-size: 13.5px; } .staak-btn-outlined{display: block;background-color: white;border: 1px solid #5B4FE3; padding: 11px 30px;width:
			max-content;border-radius: 6px;cursor: pointer;font-size: 15px;text-align: center;transition: .2s ease;text-decoration: none;}
			.staak-btn{display: block; background:#5B4FE3; color:#ffffff !important; padding: 11px 30px;width: max-content;border-radius: 6px;cursor:
			pointer;font-size: 15px;text-align: center;transition: .2s ease;text-decoration: none;} .staak-btn:hover{ background: #7065e7; }
			h1,h2,h3,h4,h5,p{ margin: 0; } a{text-decoration: none;} .my-link{color:#5B4FE3 ;font-weight: 500;}
		</style>
	</head>
	<body>
		<div class='staak-email-container'>
			<center>
				<table class='header sized-table'>
					<tr>
						<td>
							<img src='{{STAAK_ENV.APP_URL}}/cdn/public/images/staak.png' width='140' />
						</td>
					</tr>
				</table>

				<table class='main-content sized-table'>
					<tr>
						<td>
							<table style='border-collapse: collapse; width:100%'>
								{{{body}}}
							</table>
						</td>
					</tr>

				</table>

				<table class='footer sized-table'>
					<tr>
						<td style='width: 100%;'>
							<img src='{{STAAK_ENV.APP_URL}}/cdn/public/images/staak.png' width='120' />
						</td>
						<td>
							<table>
								<tr>
									<td class='social-icon'><img src='{{STAAK_ENV.APP_URL}}/cdn/public/images/linkedin.png' width='32' /></td>
									<td class='social-icon'><img src='{{STAAK_ENV.APP_URL}}/cdn/public/images/instagram.png' width='32' /></td>
									<td class='social-icon'><img src='{{STAAK_ENV.APP_URL}}/cdn/public/images/facebook.png' width='32' /></td>
									<td class='social-icon'><img src='{{STAAK_ENV.APP_URL}}/cdn/public/images/twitter.png' width='32' /></td>
								</tr>
							</table>
						</td>
					</tr>
					<tr>
						<td style='padding-top: 18px'>
							<table>
								<tr>
									<td style='padding-right: 15px; border-right: 2px solid #b3b1b1;'>
										<a href='/' class='gray-text small-text'>Our blog</a>
									</td>
									<td style='padding-right: 15px;padding-left: 15px; border-right: 2px solid #b3b1b1;'>
										<a href='/' class='gray-text small-text'>Terms & Conditions</a>
									</td>
									<td style='padding-left: 15px;'>
										<a href='/' class='gray-text small-text'>Privacy Policy</a>
									</td>
								</tr>
							</table>
						</td>

					</tr>
					<tr>
						<td style='padding-top: 10px'>
							<span class='gray-text small-text'>©2022 Staak Technologies, a IT company Bahrain Car
								<br />
								.Park Company Building, Manama, Bahrain</span>
						</td>
					</tr>
					<tr>
						<td style='padding-top: 10px'>
							<span class='gray-text small-text'>All rights reserved.</span>
						</td>
					</tr>
				</table>
			</center>
		</div>
	</body>
</html>